# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── NotebookLM (optional) ────────────────────────────────────────────────────
# Your NotebookLM notebook ID — found in the URL:
# notebooklm.google.com/notebooklm#notebook/{NOTEBOOK_ID}
NOTEBOOKLM_NOTEBOOK_ID=your-notebook-id-here

# Your browser storage state JSON — exported after logging into NotebookLM.
# Required for analyze_leads.py and export_notebook_knowledge.py to call NotebookLM.
# If not set, analyze_leads.py skips NotebookLM and uses fallback email hooks.
NOTEBOOKLM_STORAGE_STATE={"cookies":[...],"origins":[...]}
